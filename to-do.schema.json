{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://draftpine.local/to-do.schema.json",
  "title": "Draftpine planning backlog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "title",
    "objective",
    "source_files",
    "created_at",
    "updated_at",
    "principles",
    "milestones",
    "tasks"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Version of this planning file format."
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "paused", "complete"],
      "default": "active"
    },
    "source_files": {
      "type": "array",
      "description": "Relative paths treated as ground truth for this backlog.",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "created_at": {
      "type": "string",
      "format": "date"
    },
    "updated_at": {
      "type": "string",
      "format": "date"
    },
    "principles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "non_goals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "decision_log": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decision"
      },
      "default": []
    },
    "open_questions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/open_question"
      },
      "default": []
    },
    "milestones": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/milestone"
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/task"
      }
    }
  },
  "$defs": {
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "date", "decision", "rationale"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^D[0-9]{3}$"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "decision": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "implications": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      }
    },
    "open_question": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "question", "owner", "status"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^Q[0-9]{3}$"
        },
        "question": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["open", "answered", "deferred"]
        },
        "resolution": {
          "type": "string"
        }
      }
    },
    "milestone": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "description", "outcome", "task_ids"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^M[0-9]{2}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "outcome": {
          "type": "string",
          "minLength": 1
        },
        "task_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^T[0-9]{3}$"
          },
          "uniqueItems": true
        }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "priority", "status"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^T[0-9]{3}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "description": "1 is highest priority, 5 is lowest priority."
        },
        "status": {
          "type": "string",
          "enum": ["todo", "doing", "blocked", "done"]
        },
        "phase": {
          "type": "string",
          "enum": [
            "strategy",
            "source-model",
            "theme-system",
            "compiler",
            "evaluation",
            "migration",
            "docs",
            "release"
          ]
        },
        "type": {
          "type": "string",
          "enum": ["design", "implementation", "test", "documentation", "migration", "release"]
        },
        "details": {
          "type": "string"
        },
        "rationale": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "acceptance_criteria": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "validation": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "risks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^T[0-9]{3}$"
          },
          "uniqueItems": true,
          "default": []
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true,
          "default": []
        },
        "created_at": {
          "type": "string",
          "format": "date"
        },
        "updated_at": {
          "type": "string",
          "format": "date"
        }
      }
    }
  }
}
