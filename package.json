{
  "name": "draftpine",
  "version": "3.0.0",
  "description": "Page JSON and editable HTML theme compiler for static prototypes.",
  "type": "module",
  "bin": {
    "draftpine": "./dist/src/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run tests/integration",
    "test:corpus": "vitest run tests/integration/fixtures.test.ts",
    "test:lite": "vitest run tests/integration/fixtures.test.ts",
    "check:fixtures": "tsx src/cli/index.ts check fixtures/good/lite-basic",
    "draftpine": "tsx src/cli/index.ts",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@playwright/test": "^1.56.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=20"
  }
}
