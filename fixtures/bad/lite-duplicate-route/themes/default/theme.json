      ],
      "markers": [
        "primaryAction"
      ]
    },
    "careers": {
      "file": "blocks/careers.html",
      "description": "Careers intro with company perks.",
      "requires": [
        "perks"
      ]
    },
    "job-list": {
      "file": "blocks/job-list.html",
      "description": "Public job listing rows.",
      "requires": [
        "jobs"
      ]
    },
    "changelog": {
      "file": "blocks/changelog.html",
      "description": "Public changelog or release notes list.",
      "requires": [
        "items"
      ]
    },
    "locations": {
      "file": "blocks/locations.html",
      "description": "Office, event, or service area cards.",
      "requires": [
        "locations"
      ]
    },
    "integrations-grid": {
      "file": "blocks/integrations-grid.html",
      "description": "Public integrations or ecosystem grid.",
      "requires": [
        "items"
      ]
    },
    "rich-text": {
      "file": "blocks/rich-text.html",
      "description": "Public legal, terms, or simple content body.",
      "requires": [
        "title"
      ]
    },
    "not-found": {
      "file": "blocks/not-found.html",
      "description": "Public 404 or empty route page.",
      "requires": [
        "title"
      ],
      "markers": [
        "primaryAction"
      ]
    },
    "table": {
      "file": "blocks/table.html",
