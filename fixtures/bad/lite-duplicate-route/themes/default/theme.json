{
  "schemaVersion": "3.0",
  "name": "Default",
  "description": "Default Draftpine v3 theme.",
  "shell": "shell.html",
  "styles": "styles.css",
  "supportsDarkMode": true,
  "requiredRuntime": [
    "theme",
    "filter",
    "modal",
    "tabs"
  ],
  "blocks": {
    "hero": {
      "file": "blocks/hero.html",
      "description": "Page hero with proof and primary action.",
      "requires": [
        "headline"
      ],
      "markers": [
        "primaryAction"
      ]
    },
    "proof": {
      "file": "blocks/proof.html",
      "description": "Product proof panel.",
      "requires": [
        "title"
      ]
    },
    "metrics": {
      "file": "blocks/metrics.html",
      "description": "Metric strip.",
      "requires": [
        "items"
      ]
    },
    "card-grid": {
      "file": "blocks/card-grid.html",
      "description": "Repeated cards.",
      "requires": [
        "items"
      ]
    },
    "section-header": {
      "file": "blocks/section-header.html",
      "description": "Standalone section heading with optional action.",
      "requires": [
        "title"
      ]
    },
    "banner": {
      "file": "blocks/banner.html",
      "description": "Slim announcement banner.",
      "requires": [
        "body"
      ]
    },
    "logo-cloud": {
      "file": "blocks/logo-cloud.html",
      "description": "Compact customer or integration logo row.",
      "requires": [
        "logos"
      ]
    },
    "social-proof": {
      "file": "blocks/social-proof.html",
      "description": "Public proof section with compact stats.",
      "requires": [
        "title",
        "stats"
      ]
    },
    "feature-icons": {
      "file": "blocks/feature-icons.html",
      "description": "Icon-led feature cards.",
      "requires": [
        "items"
      ]
    },
    "feature-tabs": {
      "file": "blocks/feature-tabs.html",
      "description": "Tabbed feature narrative for public pages.",
      "requires": [
        "tabs"
      ],
      "interactions": [
        "tabs"
      ]
    },
    "feature-showcase": {
      "file": "blocks/feature-showcase.html",
      "description": "Two-column feature narrative with product artifact.",
      "requires": [
        "title",
        "rows"
      ]
    },
    "testimonial": {
      "file": "blocks/testimonial.html",
      "description": "Customer quote or reviewer proof.",
      "requires": [
        "quote",
        "author"
      ]
    },
    "testimonial-grid": {
      "file": "blocks/testimonial-grid.html",
      "description": "Multiple public-facing customer quotes.",
      "requires": [
        "items"
      ]
    },
    "faq": {
      "file": "blocks/faq.html",
      "description": "Accordion FAQ section.",
      "requires": [
        "items"
      ]
    },
    "newsletter": {
      "file": "blocks/newsletter.html",
      "description": "Email capture or update signup CTA.",
      "requires": [
        "title"
      ],
      "markers": [
        "primaryAction"
      ]
    },
    "contact": {
      "file": "blocks/contact.html",
      "description": "Public contact section with form and contact details.",
      "requires": [
        "fields"
      ],
      "markers": [
        "primaryAction"
      ],
      "accessibility": {
        "requiresLabels": true
      }
    },
    "team": {
      "file": "blocks/team.html",
      "description": "People grid for about or company pages.",
      "requires": [
        "people"
      ]
    },
    "values": {
      "file": "blocks/values.html",
      "description": "Values or principles grid.",
      "requires": [
        "items"
      ]
    },
    "resource-list": {
      "file": "blocks/resource-list.html",
