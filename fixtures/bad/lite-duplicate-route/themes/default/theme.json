        "title"
      ]
    },
    "author-bio": {
      "file": "blocks/author-bio.html",
      "description": "Author or contributor biography strip.",
      "requires": [
        "name"
      ]
    },
    "steps": {
      "file": "blocks/steps.html",
      "description": "Process or onboarding steps.",
      "requires": [
        "items"
      ]
    },
    "case-study": {
      "file": "blocks/case-study.html",
      "description": "Featured public case study with result metrics.",
      "requires": [
        "title"
      ]
    },
    "case-study-grid": {
      "file": "blocks/case-study-grid.html",
