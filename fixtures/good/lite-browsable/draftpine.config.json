{
  "schemaVersion": "3.0",
  "project": {
    "name": "Lite Browsable",
    "description": "Static Draftpine v3 prototype."
  },
  "source": {
    "mode": "pages",
    "pagesDir": "pages",
    "theme": "default",
    "themesDir": "themes"
  },
  "output": {
    "dir": "prototype",
    "clean": true,
    "assetsDir": "assets"
  },
  "theme": {
    "defaultMode": "light",
    "allowThemeToggle": true
  },
  "eval": {
    "required": true,
    "strict": true,
    "viewports": [
      "mobile",
      "desktop"
    ],
    "aiReview": "off"
  }
}
