{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://draftpine.local/schemas/screen-packet.schema.json",
  "title": "Draftpine Screen Packet",
  "type": "object",
  "required": ["screen", "audience", "userGoal", "primaryAction"],
  "properties": {
    "screen": { "type": "string", "minLength": 1 },
    "audience": { "type": "string", "minLength": 1 },
    "userGoal": { "type": "string", "minLength": 1 },
    "primaryAction": { "type": "string", "minLength": 1 },
    "designProfile": {
      "type": "string",
      "enum": ["editorial", "saas", "marketing", "docs", "app"],
      "default": "editorial"
    },
    "prototypeMode": {
      "type": "string",
      "enum": ["single-screen", "browsable"],
      "default": "single-screen"
    },
    "contentMode": {
      "type": "string",
      "enum": ["inline", "json"],
      "default": "inline"
    },
    "contentFiles": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "route": {
      "type": "string",
      "default": "/"
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "title", "file"],
        "properties": {
          "path": { "type": "string" },
          "title": { "type": "string" },
          "file": { "type": "string" }
        },
        "additionalProperties": true
      },
      "default": []
    },
    "patterns": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "sections": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "states": {
      "type": "array",
      "items": { "type": "string" },
      "default": ["default"]
    },
    "interactions": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "doNotInclude": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    }
  },
  "additionalProperties": true
}
