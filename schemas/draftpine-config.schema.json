{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://draftpine.local/schemas/draftpine-config.schema.json",
  "title": "Draftpine Config",
  "type": "object",
  "required": ["screen", "audience", "userGoal", "primaryAction", "requiredStates", "requiredInteractions"],
  "properties": {
    "screen": { "type": "string" },
    "audience": { "type": "string" },
    "userGoal": { "type": "string" },
    "primaryAction": { "type": "string" },
    "prototypeMode": {
      "type": "string",
      "enum": ["single-screen", "browsable"],
      "default": "single-screen"
    },
    "contentMode": {
      "type": "string",
      "enum": ["inline", "json"],
      "default": "inline"
    },
    "contentFiles": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[^/].*\\.json$"
      },
      "default": []
    },
    "patterns": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "title", "file"],
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^/"
          },
          "title": { "type": "string" },
          "file": {
            "type": "string",
            "pattern": "^[^/].*\\.html$"
          }
        },
        "additionalProperties": true
      },
      "default": []
    },
    "template": {
      "type": "string",
      "deprecated": true,
      "description": "Deprecated. Prefer patterns."
    },
    "requiredStates": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requiredInteractions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
