{
  "schemaVersion": "2.0",
  "name": "productMockup",
  "namespace": "core",
  "type": "primitive",
  "description": "A bounded product UI artifact card for showing workflow state, schedules, lists, and product chrome.",
  "slots": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "toolbar": {
      "type": "array"
    },
    "panels": {
      "type": "array",
      "required": true
    },
    "activity": {
      "type": "array"
    }
  },
  "variants": ["calendar", "workflow", "dashboard"],
  "layouts": ["core.stack", "core.gridAuto"],
  "interactions": [],
  "states": ["default"],
  "accessibility": {},
  "responsive": {
    "mobile": "stack"
  }
}
