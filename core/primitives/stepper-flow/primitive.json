{
  "schemaVersion": "2.0",
  "name": "stepperFlow",
  "namespace": "core",
  "type": "primitive",
  "description": "Step-based flow for onboarding, checkout, intake, and setup screens.",
  "slots": {
    "title": { "type": "string", "required": true },
    "description": { "type": "text" },
    "steps": { "type": "array" },
    "summary": { "type": "object" },
    "primaryAction": { "type": "action" }
  },
  "variants": ["checkout", "onboarding", "intake"],
  "layouts": ["core.stack", "core.split"],
  "interactions": [],
  "states": ["default", "empty", "success"],
  "accessibility": { "requiresHeading": true, "requiresPrimaryAction": true }
}
